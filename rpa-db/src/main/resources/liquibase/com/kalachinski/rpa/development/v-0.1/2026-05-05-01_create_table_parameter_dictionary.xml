<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="2026-05-05-01" author="Yury Kalachinski">
        <comment>Creating table: parameter_dictionary</comment>

        <createTable tableName="parameter_dictionary" schemaName="main">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_parameter_dictionary"/>
            </column>
            <column name="key" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="unit" type="varchar(64)"/>
            <column name="description" type="varchar(64)"/>
            <column name="priority" type="smallint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
